---
/* Image should be something showing longevity or 
   a close-up of aged, high-quality wood grain. */
const legacyImage = "https://images.unsplash.com/photo-1497366811353-6870744d04b2?auto=format&fit=crop&q=80&w=1600";
---

<section class="bg-wall py-24 flex justify-center">
    <div class="relative w-[95%] h-[100vh] overflow-hidden border-2 border-ebony group">
        
        <div 
            class="absolute inset-0 z-0 bg-fixed bg-center bg-cover grayscale-[20%] brightness-50"
            style={`background-image: url('${legacyImage}');`}
        >
        </div>

        <div class="relative z-10 h-full w-full flex flex-col justify-center items-center text-center px-6 md:px-24">
            
            <span class="text-brand-orange font-bold uppercase tracking-[0.3em] mb-8">
                Since 1981
            </span>

            <h2 class="text-display-lg text-wall max-w-4xl mb-12">
                "It’s an immense pleasure when a client we supplied decades ago calls us to maintain our earlier works."
            </h2>

            

        </div>
    </div>
</section>

<style>
    /* Ensure the fixed background works smoothly */
    .bg-fixed {
        background-attachment: fixed;
    }

    /* Mobile fix: background-attachment: fixed is notoriously buggy on iOS, 
       so we fallback to a standard scroll on small screens for performance. */
    @media (max-width: 768px) {
        .bg-fixed {
            background-attachment: scroll;
        }
    }
</style>